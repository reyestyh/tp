@startuml
!include style.puml
hide footbox

box Logic LOGIC_COLOR_T1
participant ":EditCommandParser" as parser LOGIC_COLOR
participant ":EditXYZDescriptor" as descriptor LOGIC_COLOR
participant ":EditXYZCommand" as command LOGIC_COLOR
end box

participant ":Model" as model MODEL_COLOR

[-> parser : parse("FLAG INDEX FIELD")
activate parser
note right: FLAG is either /contact or /itinerary, which specifies the type\nof entry being edited (Person or Itinerary respectively).\nINDEX specifies the target entry being edited.\nFIELD specifies the fields being edited.

parser -> parser : tokenize by prefixes
note right: Splits "INDEX FIELD" into\nindex and field parameters

create descriptor
parser -> descriptor : new EditXYZDescriptor()
activate descriptor
descriptor --> parser
deactivate descriptor
note right: XYZ is a placeholder for the type of entry\nbeing edited (either Person or Itinerary)

parser -> parser : parse and set values for\nedited fields in descriptor

parser -> descriptor : isAnyFieldEdited()
activate descriptor
descriptor --> parser
deactivate descriptor

create command
parser -> command : new EditXYZCommand(index, descriptor)
activate command
command --> parser
deactivate command

[<-- parser : command
deactivate parser

parser -[hidden]-> parser
destroy parser

...

[-> command : execute(model)
activate command

command -> model : getFilteredXYZList()
activate model
model --> command
deactivate model

command -> command : createEditedXYZ()
note right: Merges original fields\nwith descriptor values

alt duplicate entry
    [<-- command : throw CommandException
else valid edit
    command -> model : setXYZ(original, edited)
    activate model
    model --> command
    deactivate model

    command -> model : updateFilteredXYZList()
    activate model
    model --> command
    deactivate model

    [<-- command : CommandResult
end

deactivate command

@enduml
