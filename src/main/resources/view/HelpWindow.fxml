<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.stage.Stage?>

<fx:root resizable="true" title="Help" type="javafx.stage.Stage" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <icons>
        <Image url="@/images/help_icon.png" />
    </icons>
    <scene>
        <Scene>
            <stylesheets>
                <URL value="@HelpWindow.css" />
                <URL value="@DarkTheme.css" />
            </stylesheets>
            <AnchorPane fx:id="mainLayout" styleClass="background">
                <ScrollPane fx:id="helpScrollPane">
                    <Label fx:id="helpMessage" styleClass="label" wrapText="true"/>
                </ScrollPane>
                <HBox alignment="CENTER_RIGHT" fx:id="bottomBar" styleClass="pane-with-border">
                    <Button fx:id="copyButton" mnemonicParsing="false" onAction="#copyUrl" text="Copy URL"/>
                </HBox>
            </AnchorPane>
        </Scene>
    </scene>
</fx:root>
